# Cloudflare Pages Headers
# 정적 파일 캐시 무효화를 위한 설정

# HTML 페이지 - 캐시 안함 (항상 최신 버전)
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# API 응답 - 캐시 안함
/api/*
  Cache-Control: no-cache, no-store, must-revalidate

# 정적 JS/CSS 파일 - 버전 쿼리스트링 사용시 캐시 가능
# 버전이 바뀌면 URL이 바뀌므로 새로 로드됨
/static/*
  Cache-Control: public, max-age=31536000, immutable

# _worker.js - 캐시 안함 (서버 코드)
/_worker.js
  Cache-Control: no-cache, no-store, must-revalidate
